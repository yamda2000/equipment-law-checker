# ────────────────────────────────────────────────────────────
# アクティブ環境設定
# poc : OpenAI API を使用
# prod: Azure OpenAI を使用
# ────────────────────────────────────────────────────────────
LLM_MODE=poc

# ────────────────────────────────────────────────────────────
# 主要LLM - PoC環境 (OpenAI API)
# ────────────────────────────────────────────────────────────
POC_LLM_PROVIDER=openai
POC_LLM_API_KEY=sk-...
POC_LLM_MODEL=gpt-4o

# ────────────────────────────────────────────────────────────
# 主要LLM - 本番環境 (Azure OpenAI)
# ────────────────────────────────────────────────────────────
PROD_LLM_PROVIDER=azure
PROD_LLM_API_KEY=
PROD_LLM_ENDPOINT=https://<リソース名>.openai.azure.com/
PROD_LLM_API_VERSION=2024-02-01
PROD_LLM_DEPLOYMENT=<デプロイ名>
# デプロイ名は管理者が自由に付けた名前で Langfuse の単価表と一致しないため、
# 実際のモデル名（例: gpt-4o）を別途指定する。Langfuse のコスト自動計算に使われる
PROD_LLM_MODEL=gpt-4o

# ────────────────────────────────────────────────────────────
# Embedding - PoC環境 (OpenAI)
# 社内文書RAG・ケースメモリのベクトル化に使用。
# API_KEY 未設定時は POC_LLM_API_KEY を流用する。
# ※ モデルを変更すると既存インデックスと次元が合わなくなるため、
#    社内文書・ケースメモリの再登録が必要
# ────────────────────────────────────────────────────────────
POC_EMBEDDING_PROVIDER=openai
POC_EMBEDDING_API_KEY=
POC_EMBEDDING_MODEL=text-embedding-3-small

# ────────────────────────────────────────────────────────────
# Embedding - 本番環境 (Azure OpenAI)
# API_KEY / ENDPOINT / API_VERSION 未設定時は PROD_LLM_* を流用する
# ────────────────────────────────────────────────────────────
PROD_EMBEDDING_PROVIDER=azure
PROD_EMBEDDING_API_KEY=
PROD_EMBEDDING_ENDPOINT=https://<リソース名>.openai.azure.com/
PROD_EMBEDDING_API_VERSION=2024-02-01
PROD_EMBEDDING_DEPLOYMENT=<Embeddingデプロイ名>

# ────────────────────────────────────────────────────────────
# ベクトルストア（社内文書RAG・ケースメモリ）
# chroma（既定）または faiss。切り替えるとインデックスは共有されない
# ため、社内文書の再登録が必要
# ────────────────────────────────────────────────────────────
VECTOR_STORE=chroma

# ────────────────────────────────────────────────────────────
# Web検索AI - Gemini Google Search Grounding (PoC/本番共通)
# ※ Gemini API 無料枠では送信内容（検索クエリ含む）が Google の
#    プロダクト改善に利用され得る。機密情報を扱う運用では、Cloud 請求先
#    アカウントを有効化した有料枠の使用を推奨（有料枠は改善利用されない）
# ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_WEB_SEARCH_MODEL=gemini-2.0-flash
# 利用可能なモデル例: gemini-2.0-flash / gemini-2.0-flash-lite / gemini-1.5-flash
# GEMINI_WEB_SEARCH_TIMEOUT_MS=60000  # Web検索1回のタイムアウト（ミリ秒・既定60秒）

# ────────────────────────────────────────────────────────────
# Langfuse（LLMトレース・コスト計測。任意）
# 設定すると、全LLM呼び出し・Gemini Web検索のリクエスト内容・トークン数・
# コストが Langfuse に記録される（thread_id ごとにセッションでグルーピング）。
# 未設定の場合、トレースは無効（アプリの動作は変わらない）
# ────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# セルフホストの場合はそのURL。Langfuse Cloud なら既定のままでよい
LANGFUSE_HOST=https://cloud.langfuse.com

# ────────────────────────────────────────────────────────────
# 資料アップロードの読み込み設定（任意）
# 長い資料は下記 DOC_CHUNK_CHARS 単位に分割し、パートごとに抽出して統合するため、
# 末尾の情報が切り捨てられずに読まれる（分割した数だけLLM呼び出し＝コストが増える）。
#
# DOC_CHUNK_CHARS: 1回の抽出に渡す文字数。既定45,000字（gpt-4o等で安全な目安）。
#   大きくすると呼び出し回数は減るが、モデルのコンテキスト窓を超えるとエラーになる。
# DOC_MAX_TEXT_CHARS: 全資料合計の絶対上限（暴走防止の安全弁）。既定480,000字。
#   これを超える巨大アップロードのみ、超過分を末尾から切り捨てて警告する。
#   分割抽出のLLM呼び出し回数の上限は概ね DOC_MAX_TEXT_CHARS / DOC_CHUNK_CHARS。
# ────────────────────────────────────────────────────────────
# DOC_CHUNK_CHARS=45000
# DOC_MAX_TEXT_CHARS=480000

# ────────────────────────────────────────────────────────────
# コスト表示（サイドバーの概算に使用・すべて任意）
# ※ Langfuse 設定時はコスト計測を Langfuse に一本化し、サイドバーの
#    概算表示は行われない（以下の単価設定も使われない）。
#    こちらは Langfuse 未設定時の簡易表示にのみ使用
# 単価は USD / 100万トークン。既定は gpt-4o / gemini-2.0-flash 相当
# ────────────────────────────────────────────────────────────
# LLM_COST_INPUT_PER_1M=2.5        # LLM入力単価。未設定の場合、単価不明の呼び出しは
#                                  # 金額に計上されず「単価不明」と表示される（誤額を出さない）
# LLM_COST_OUTPUT_PER_1M=10.0      # LLM出力単価（同上）
# GEMINI_COST_INPUT_PER_1M=0.10    # Gemini Web検索の入力単価
# GEMINI_COST_OUTPUT_PER_1M=0.40   # Gemini Web検索の出力単価
# GEMINI_COST_PER_SEARCH=0         # 検索1回の課金（無料枠1,500回/日を超える有料運用時は 0.035）
# LLM_COST_JPY_RATE=150            # 円換算レート（円/ドル）
