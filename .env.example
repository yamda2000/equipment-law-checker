# ────────────────────────────────────────────────────────────
# アクティブ環境設定
# poc : OpenAI API を使用
# prod: Azure OpenAI を使用
# ────────────────────────────────────────────────────────────
LLM_MODE=poc

# ────────────────────────────────────────────────────────────
# 主要LLM - PoC環境 (OpenAI API)
# ────────────────────────────────────────────────────────────
POC_LLM_PROVIDER=openai
POC_LLM_API_KEY=sk-...
POC_LLM_MODEL=gpt-4o

# ────────────────────────────────────────────────────────────
# 主要LLM - 本番環境 (Azure OpenAI)
# ────────────────────────────────────────────────────────────
PROD_LLM_PROVIDER=azure
PROD_LLM_API_KEY=
PROD_LLM_ENDPOINT=https://<リソース名>.openai.azure.com/
PROD_LLM_API_VERSION=2024-02-01
PROD_LLM_DEPLOYMENT=<デプロイ名>

# ────────────────────────────────────────────────────────────
# Embedding - PoC環境 (OpenAI)
# 社内文書RAG・ケースメモリのベクトル化に使用。
# API_KEY 未設定時は POC_LLM_API_KEY を流用する。
# ※ モデルを変更すると既存インデックスと次元が合わなくなるため、
#    社内文書・ケースメモリの再登録が必要
# ────────────────────────────────────────────────────────────
POC_EMBEDDING_PROVIDER=openai
POC_EMBEDDING_API_KEY=
POC_EMBEDDING_MODEL=text-embedding-3-small

# ────────────────────────────────────────────────────────────
# Embedding - 本番環境 (Azure OpenAI)
# API_KEY / ENDPOINT / API_VERSION 未設定時は PROD_LLM_* を流用する
# ────────────────────────────────────────────────────────────
PROD_EMBEDDING_PROVIDER=azure
PROD_EMBEDDING_API_KEY=
PROD_EMBEDDING_ENDPOINT=https://<リソース名>.openai.azure.com/
PROD_EMBEDDING_API_VERSION=2024-02-01
PROD_EMBEDDING_DEPLOYMENT=<Embeddingデプロイ名>

# ────────────────────────────────────────────────────────────
# ベクトルストア（社内文書RAG・ケースメモリ）
# chroma（既定）または faiss。切り替えるとインデックスは共有されない
# ため、社内文書の再登録が必要
# ────────────────────────────────────────────────────────────
VECTOR_STORE=chroma

# ────────────────────────────────────────────────────────────
# Web検索AI - Gemini Google Search Grounding (PoC/本番共通)
# ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_WEB_SEARCH_MODEL=gemini-2.0-flash
# 利用可能なモデル例: gemini-2.0-flash / gemini-2.0-flash-lite / gemini-1.5-flash

# ────────────────────────────────────────────────────────────
# コスト表示（サイドバーの概算に使用・すべて任意）
# 単価は USD / 100万トークン。既定は gpt-4o / gemini-2.0-flash 相当
# ────────────────────────────────────────────────────────────
# LLM_COST_INPUT_PER_1M=2.5        # LLM入力単価（単価表が引けない場合の概算用）
# LLM_COST_OUTPUT_PER_1M=10.0      # LLM出力単価
# GEMINI_COST_INPUT_PER_1M=0.10    # Gemini Web検索の入力単価
# GEMINI_COST_OUTPUT_PER_1M=0.40   # Gemini Web検索の出力単価
# GEMINI_COST_PER_SEARCH=0         # 検索1回の課金（無料枠1,500回/日を超える有料運用時は 0.035）
# LLM_COST_JPY_RATE=150            # 円換算レート（円/ドル）

# ────────────────────────────────────────────────────────────
# アプリ設定
# ────────────────────────────────────────────────────────────
# DEV_MODE=true にするとAI呼び出しをスキップしモックを返す
DEV_MODE=false
